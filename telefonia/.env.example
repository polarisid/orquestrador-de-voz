# =============================================================
# telefonia/.env  —  usado pelo gerar-config.sh e pelo docker compose
#
# Depois de qualquer mudanca aqui:
#   bash gerar-config.sh && docker restart asterisk-triagem
#
# NUNCA versione este arquivo. O .gitignore ja cobre.
# =============================================================

# ---- Tronco iFalei (saida para o cliente) -------------------
# Confira o servidor no e-mail de ativacao: pode ser
# sip.ifalei.com.br ou sip20.pabxsip.com.br
IFALEI_SERVIDOR=sip.ifalei.com.br
IFALEI_USUARIO=adeilto-102
IFALEI_SENHA=

# Numero que aparece no visor do cliente. So digitos, com DDD.
# Use um DID de Aracaju: numero local reconhecivel e atendido
# muito mais que um desconhecido.
CALLER_ID_SAIDA=7933000000

# ---- Ponte para a ElevenLabs (entrada) ----------------------
# Estas credenciais VOCE inventa aqui e cadastra no painel da
# ElevenLabs, em Outbound SIP Trunk Configuration.
# Use so letras e numeros: simbolos quebram o envsubst e o
# formulario deles.
EL_SIP_USUARIO=elevenlabs
EL_SIP_SENHA=

# O DID exatamente como a ElevenLabs manda no campo From, COM o +.
# E o nome do endpoint no Asterisk; sem isso a autenticacao
# entra em loop de 401.
EL_FROM_USER=+557930238185

# ---- ARI (desligar e escutar pelo painel) -------------------
# A MESMA senha precisa estar no .env do orquestrador (Coolify).
ARI_SENHA=

# ---- Ramal de escuta por softphone --------------------------
# Registre MicroSIP ou Zoiper no IP da VPS, TCP 5060,
# usuario "escuta". Disque 90 para entrar em modo espiao.
ESCUTA_SENHA=

# ---- Teste manual -------------------------------------------
# Seu celular, formato 55 + DDD + numero
NUMERO_TESTE=5579999998888
