PORT=3001
PUBLIC_URL=https://voz.smartcenteraracaju.com.br
WEBHOOK_SECRET=troque-isto


# Ramal de transbordo (iFalei)
# --- ElevenLabs Agents ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=            # sai do scripts/criar-agente-elevenlabs.mjs
ELEVENLABS_PHONE_NUMBER_ID=     # sai do painel, apos importar o numero SIP
ELEVENLABS_VOICE_ID=            # voz pt-BR escolhida no painel

# --- Importacao do numero SIP (scripts/importar-numero-elevenlabs.mjs) ---
EL_NUMERO=                      # DID iFalei em E.164, ex: +557933000000
EL_ENDERECO=31.97.86.62         # IP da VPS onde roda o Asterisk
EL_SIP_USUARIO=elevenlabs       # mesmo valor de telefonia/.env
EL_SIP_SENHA=                   # mesmo valor de telefonia/.env

# --- Asterisk (desligar e escutar pelo painel) ---
# DEIXE VAZIO: o orquestrador descobre o gateway da propria rede sozinho.
# Preencha so se o /diagnostico indicar outro endereco.
ASTERISK_ARI_URL=
ARI_USUARIO=triagem
ARI_SENHA=

RAMAL_ATENDIMENTO=1001

# Triagem AI (Next.js existente)
TRIAGEM_API_URL=https://triagem.smartcenteraracaju.com.br
TRIAGEM_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Chave anon (publica por design) — habilita o login do painel
SUPABASE_ANON_KEY=
# Schema das tabelas de voz. Deixe 'voz' para isolar do resto do projeto.
SUPABASE_SCHEMA=voz

# iFalei — SMS
IFALEI_API_URL=https://painelv2.ifalei.com.br
IFALEI_TOKEN=            # Integrações > API de Integração > Gerar Token
IFALEI_USUARIO_ID_ORIGEM= # solicitar ao suporte iFalei

# WhatsApp (Meta Cloud API)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_TEMPLATE_DOCS=envio_documentos_os

# Portal de upload
PORTAL_URL=https://triagem.smartcenteraracaju.com.br
