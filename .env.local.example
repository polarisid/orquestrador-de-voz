# Perfil de TESTE LOCAL. Copie para .env e rode. Nada a preencher.
# DRY_RUN=true ignora a janela de horário e não envia SMS/WhatsApp de verdade.
DRY_RUN=true

PORT=3001
PUBLIC_URL=http://localhost:3001
WEBHOOK_SECRET=troque-isto

# --- ElevenLabs Agents ---
# Só para teste local, apontando ao mock. Em produção, apague esta linha.
ELEVENLABS_API_URL=http://localhost:4000
ELEVENLABS_API_KEY=fake
ELEVENLABS_AGENT_ID=fake
ELEVENLABS_PHONE_NUMBER_ID=fake
ELEVENLABS_VOICE_ID=

# --- Importacao do numero SIP (scripts/importar-numero-elevenlabs.mjs) ---
EL_NUMERO=                      # DID iFalei em E.164, ex: +557933000000
EL_ENDERECO=31.97.86.62         # IP da VPS onde roda o Asterisk
EL_SIP_USUARIO=elevenlabs       # mesmo valor de telefonia/.env
EL_SIP_SENHA=                   # mesmo valor de telefonia/.env

# --- Asterisk (desligar e escutar pelo painel) ---
# DEIXE VAZIO: o orquestrador descobre o gateway da propria rede sozinho.
# Preencha so se o /diagnostico indicar outro endereco.
ASTERISK_ARI_URL=
ARI_USUARIO=triagem
ARI_SENHA=

# Quantas ligacoes a fila dispara ao mesmo tempo.
# Ramal iFalei aguenta 1. Tronco com varios canais aguenta mais.
MAX_CHAMADAS_SIMULTANEAS=1

# Segundos entre a tool encerrar_triagem e derrubar o canal no Asterisk.
# E rede de seguranca: o agente deveria encerrar sozinho. 0 desliga o recurso.
SEGUNDOS_ATE_DESLIGAR=12

# Para onde o agente transfere quando o cliente pede um humano.
# E.164 e o caminho robusto: a central distribui para quem estiver livre.
#   NUMERO_TRANSBORDO=+557933000000
# Ramal direto tambem funciona, via SIP URI:
#   NUMERO_TRANSBORDO=sip:1001@sip.ifalei.com.br
NUMERO_TRANSBORDO=

RAMAL_ATENDIMENTO=1001

TRIAGEM_API_URL=http://localhost:4001
TRIAGEM_API_KEY=fake

PORTAL_URL=http://localhost:3000

# Deixe VAZIO para usar o store local em ./dados/store.json.
# Preencha quando quiser plugar o Supabase — nenhum código muda.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Chave anon (publica por design) — habilita o login do painel
SUPABASE_ANON_KEY=
# Schema das tabelas de voz. Deixe 'voz' para isolar do resto do projeto.
SUPABASE_SCHEMA=voz

IFALEI_API_URL=https://painelv2.ifalei.com.br
IFALEI_TOKEN=
IFALEI_USUARIO_ID_ORIGEM=
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_TEMPLATE_DOCS=envio_documentos_os
